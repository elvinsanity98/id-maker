# ─── Supabase ──────────────────────────────────────────────
# 1. Create a project at https://supabase.com (free tier is fine).
# 2. Project Settings → API → copy the URL and the "anon public" key.
# 3. Run the SQL in /supabase/init.sql in your Supabase SQL editor.
# 4. Copy this file to .env.local and fill in the values.
# 5. On Vercel, set these as Environment Variables (Production + Preview).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ─── Premium pricing & payment details (shown in Upgrade modal) ──
NEXT_PUBLIC_PREMIUM_PRICE_PHP=500
NEXT_PUBLIC_GCASH_NAME=Elvin Jhon
NEXT_PUBLIC_GCASH_NUMBER=0917-XXX-XXXX
NEXT_PUBLIC_PAYMENT_CONTACT_EMAIL=you@example.com
# Optional: hosted Gumroad / Lemon Squeezy / PayHip URL for card buyers.
NEXT_PUBLIC_STOREFRONT_URL=https://gumroad.com/l/idmaker-premium
